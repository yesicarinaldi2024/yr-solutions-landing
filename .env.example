# ─── YR Solutions — Variables de Entorno ────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA comitees el archivo .env al repositorio (CLAUDE.md REGLA-001).

# ─── Servidor ────────────────────────────────────────────────────────────────
# Puerto en el que correrá el servidor Express
PORT=3000

# Entorno de ejecución: development | production
NODE_ENV=development

# URL del frontend (usada para CORS en desarrollo)
FRONTEND_URL=http://localhost:5500

# ─── Configuración SMTP ───────────────────────────────────────────────────────
# Host del servidor de correo saliente
# Ejemplos: smtp.gmail.com | smtp.hostinger.com | mail.yrsolutions.com.ar
EMAIL_HOST=smtp.hostinger.com

# Puerto SMTP
# 465 → SSL (secure: true)   |   587 → TLS/STARTTLS (secure: false)
EMAIL_PORT=587

# Dirección de email que se usará para autenticarse y enviar los correos
EMAIL_USER=hola@yrsolutions.com.ar

# Contraseña de la cuenta de correo (o App Password si usas Gmail con 2FA)
EMAIL_PASS=tu_contraseña_aqui

# Dirección donde se recibirán las notificaciones del formulario de contacto
EMAIL_TO=hola@yrsolutions.com.ar
